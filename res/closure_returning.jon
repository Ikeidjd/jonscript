fn add(a: int) -> fn[(int) -> int][] {
    mut a: int = a;

    fn out(b: int) -> int {
        return a + b;
    }

    fn out2(b: int) -> int {
        a = a + 10;
        return a;
    }

    return [out, out2];
}

let add_10: fn[(int) -> int][] = add(10);
println(add_10[0](10));
println(add_10[1](10));
println(add_10[0](20));
println(add_10[1](20));